{
  "name": "nestjs-ecommerce",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "cross-env NODE_ENV=dev  nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:fix": "eslint . --fix",
    "pre-commit": "lint-staged",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "NODE_ENV=e2e jest --config ./test/jest-e2e.json --verbose --forceExit --runInBand --detectOpenHandles",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d typeorm.config.ts",
    "migration:create": "cross-env NODE_ENV=dev npm run typeorm -- migration:create -n",
    "migration:generate": "cross-env NODE_ENV=dev npm run typeorm migration:generate ./src/database/migrations/$npm_config_name",
    "migration:run-dev": "cross-env NODE_ENV=dev npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "prepare": "husky install"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "*",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.1.6",
    "@nestjs/typeorm": "^11.0.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^16.5.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.15.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.22"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@faker-js/faker": "^9.7.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "cross-env": "^7.0.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "husky": "^8.0.0",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.6",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testPathIgnorePatterns": [
      "<rootDir>/coverage/",
      "<rootDir>/dist/",
      "<rootDir>/faker/",
      "<rootDir>/src/database/migrations/",
      "<rootDir>/test/"
    ],
    "coveragePathIgnorePatterns": [
      "<rootDir>/coverage/",
      "<rootDir>/dist/",
      "<rootDir>/faker/",
      "<rootDir>/src/database/migrations/",
      "<rootDir>/test/"
    ],
    "moduleNameMapper": {
      "@auth/(.*)": "<rootDir>/src/auth/$1",
      "@brand/(.*)": "<rootDir>/src/brand/$1",
      "@category/(.*)": "<rootDir>/src/category/$1",
      "@commons/(.*)": "<rootDir>/src/commons/$1",
      "@config/(.*)": "<rootDir>/src/config/$1",
      "@customer/(.*)": "<rootDir>/src/customer/$1",
      "@discount/(.*)": "<rootDir>/src/discount/$1",
      "@faker/(.*)": "<rootDir>/faker/$1",
      "@payment_method/(.*)": "<rootDir>/src/payment-method/$1",
      "@product/(.*)": "<rootDir>/src/product/$1",
      "@product_images/(.*)": "<rootDir>/src/product-images/$1",
      "@product_discount/(.*)": "<rootDir>/src/product-discount/$1",
      "@product_supplier/(.*)": "<rootDir>/src/product-supplier/$1",
      "@product_tag/(.*)": "<rootDir>/src/product-tag/$1",
      "@purchase/(.*)": "<rootDir>/src/purchase/$1",
      "@purchase_detail/(.*)": "<rootDir>/src/purchase-detail/$1",
      "@sale/(.*)": "<rootDir>/src/sale/$1",
      "@sale_detail/(.*)": "<rootDir>/src/sale-detail/$1",
      "@shipment/(.*)": "<rootDir>/src/shipment/$1",
      "@shipping_company/(.*)": "<rootDir>/src/shipping-company/$1",
      "@store_detail/(.*)": "<rootDir>/src/store-detail/$1",
      "@subcategory/(.*)": "<rootDir>/src/subcategory/$1",
      "@supplier/(.*)": "<rootDir>/src/supplier/$1",
      "@tag/(.*)": "<rootDir>/src/tag/$1",
      "@user/(.*)": "<rootDir>/src/user/$1",
      "@wishlist/(.*)": "<rootDir>/src/wishlist/$1"
    },
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "./",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
